{
	"name": "tg-codenames-bot",
	"type": "module",
	"scripts": {
		"dev": "bun --watch ./bot.ts",
		"start": "bun ./bot.ts",
		"build": "bun build ./bot.ts --target bun --outfile ./build/bot.js",
		"typecheck": "bunx tsc -p tsconfig.json"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"dotenv": "^17.3.1",
		"grammy": "^1.41.1"
	}
}
